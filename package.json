{
  "name": "@design-to-storybook/monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "One-click from Figma design to production-ready Storybook components",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --parallel -r dev",
    "build": "pnpm -r build",
    "test": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "pnpm -r clean"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "keywords": [
    "figma",
    "storybook",
    "design-system",
    "code-generation",
    "react",
    "vue",
    "angular"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/h1s97x/design-to-storybook.git"
  }
}
