{
  "name": "@design-to-storybook/angular",
  "version": "0.1.0",
  "description": "Angular component and story generator for Design-to-Storybook",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@design-to-storybook/core": "workspace:*"
  },
  "peerDependencies": {
    "@angular/core": ">=14.0.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
